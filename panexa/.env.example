# ── Database ────────────────────────────────────────────
DATABASE_URL="postgresql://panexa:panexa123@localhost:5432/panexa_db?schema=public"

# ── Redis ────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET="sua-chave-secreta-jwt-aqui-min-32-chars"
JWT_ACCESS_EXPIRES="1h"
JWT_REFRESH_EXPIRES="7d"

NEXTAUTH_SECRET="sua-chave-nextauth-aqui-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# ── API ──────────────────────────────────────────────────
API_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Asaas (Pagamento) ────────────────────────────────────
ASAAS_API_KEY="$aact_sua_chave_asaas_aqui"
ASAAS_API_URL="https://sandbox.asaas.com/api/v3"
ASAAS_WEBHOOK_TOKEN="token-webhook-asaas"

# ── SendGrid (E-mail) ────────────────────────────────────
SENDGRID_API_KEY="SG.sua_chave_sendgrid_aqui"
SENDGRID_FROM_EMAIL="noreply@panexa.com.br"
SENDGRID_FROM_NAME="Panexa"

# ── Evolution API (WhatsApp) ─────────────────────────────
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY="sua-chave-evolution-api"
EVOLUTION_INSTANCE="panexa-main"

# ── AWS S3 / Cloudflare R2 ────────────────────────────────
S3_BUCKET="panexa-uploads"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="sua_access_key"
S3_SECRET_ACCESS_KEY="sua_secret_key"
S3_ENDPOINT="https://seu-account.r2.cloudflarestorage.com"  # Cloudflare R2

# ── Receita Federal API ──────────────────────────────────
CNPJ_API_URL="https://publica.cnpj.ws/cnpj"

# ── App Config ───────────────────────────────────────────
NODE_ENV="development"
PORT=3001
CORS_ORIGINS="http://localhost:3000"
